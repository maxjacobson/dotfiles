#!/usr/bin/env fish
#
# Prune branches already merged into main.
#
# Based on https://codeberg.org/pbrisbin/dotfiles/src/branch/main/git/dot-local/bin/git-prune-branches
#
###

function non_default_branches
    git branch | grep -v '^+' | grep -v ' \(main\|master\|v[0-9]\+\)$' | while read -l branch
        string trim "$branch"
    end
end

function merged_non_default_branches
    git branch --merged | grep -v '^+' | grep -v ' \(main\|master\|v[0-9]\+\)$' | while read -l branch
        string trim "$branch"
    end
end

function log_header --argument-names msg
    set_color blue
    set --local len (string length "$msg")
    set len (math "$len + 6")

    echo
    string repeat "$len" ":"
    echo ":: $msg" ::
    string repeat "$len" ":"
    echo

    set_color normal
end

function log_info --argument-names msg
    echo ":: $msg"
end

function log_unsuccessful_result --argument-names msg
    set_color red
    echo ":: ↳ $msg"
    set_color normal
end

function log_successful_result --argument-names msg
    set_color green
    echo ":: ↳ $msg"
    set_color normal
end

set --local main main

if test -n "$argv[1]"
    set main $argv[1]
end

log_info "main is $main"

if ! git branch | grep -q '^\* '"$main"'$'
    git checkout --quiet "$main"
end

log_info "Updating default branch $main"
git fetch --quiet
git pull origin "$main"

log_header "Rebasing each non-default branches"

non_default_branches | while read -l branch
    log_info "Rebasing $branch onto $main"
    git checkout --quiet "$branch"

    if git rebase "$main" >/dev/null 2>&1
        log_successful_result "Successfully rebased $branch onto $main"
    else
        log_unsuccessful_result "Failed to rebase $branch onto $main (will abort)"
        git rebase --abort
    end
    echo
end

git checkout --quiet "$main"

log_header "Deleting merged branches"

merged_non_default_branches | while read -l branch
    log_info "Deleting merged branch $branch"
    git branch --delete "$branch"

    log_info "Deleting remote merged branch origin/$branch"
    if git branch --delete --remote "origin/$branch" 2>/dev/null
        log_successful_result "Deleted remote merged branch origin/$branch"
    else
        log_unsuccessful_result "Failed to delete remote merged branch origin/$branch"
    end
    echo
end

log_info "Done!"
